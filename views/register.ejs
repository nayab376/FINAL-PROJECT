<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register - Doctor Hub</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <%- include('partials/header') %>
  <main>
    <section class="form-card">
      <div class="page-header">
        <div>
          <h2 class="page-title">Create your account</h2>
          <p class="page-subtitle">Register as a patient, doctor, or assistant and access Doctor Hub’s appointment, doctor search, and history tools.</p>
        </div>
      </div>
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>
      <form action="/register" method="post">
        <label>Name</label>
        <input type="text" name="name" required />
        <label>Email</label>
        <input type="email" name="email" required />
        <label>Password</label>
        <input type="password" name="password" required />
        <p class="help">Password must include uppercase, lowercase, digit, special character.</p>
        <label>Register as</label>
        <select name="role" required>
          <option value="patient">Patient</option>
          <option value="doctor">Doctor</option>
          <option value="assistant">Assistant</option>
        </select>
        <button type="submit">Create account</button>
      </form>
    </section>
    <footer class="footer">Start with the right role and experience an optimized patient-doctor workflow.</footer>
  </main>
</body>
</html>
